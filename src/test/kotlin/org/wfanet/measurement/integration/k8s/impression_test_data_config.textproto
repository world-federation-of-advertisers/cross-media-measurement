# proto-file: src/main/proto/wfa/measurement/integration/k8s/testing/impression_test_data_config.proto
# proto-message: wfa.measurement.integration.k8s.testing.ImpressionTestDataConfig

population_spec_resource_path: "small_population_spec.textproto"

# edp7's single-entity-key event group measured by the direct (single-publisher) and TrusTee
# (cross-publisher) measurements. Identified solely by its `creative-id` entity key (no reliance on
# event_group_reference_id).
event_groups {
  event_group_reference_id: "edpa-eg-reference-id-1"
  edp_name: "edp7"
  output_base_path: "edp/edp7"
  entity_key_specs {
    entity_type: "creative-id"
    entity_id: "edpa-eg-direct-creative"
    data_spec_resource_path: "small_data_spec.textproto"
  }
}

# Single creative-id entity key event group (edp7).
event_groups {
  event_group_reference_id: "creative-id-edpa-eg-creative-id-1"
  edp_name: "edp7"
  output_key: "creative"
  output_base_path: "edp/edp7"
  entity_key_specs {
    entity_type: "creative-id"
    entity_id: "edpa-eg-creative-id-1"
    data_spec_resource_path: "small_data_spec.textproto"
  }
  entity_metadata {
    fields {
      key: "placement"
      value { string_value: "homepage_top" }
    }
    fields {
      key: "objective"
      value { string_value: "awareness" }
    }
  }
}

# Multi-creative entity key event group with two sub-specs (edp7).
event_groups {
  event_group_reference_id: "multi-creative"
  edp_name: "edp7"
  output_key: "multi-creative"
  output_base_path: "edp/edp7"
  entity_key_specs {
    entity_type: "creative-id"
    entity_id: "edpa-eg-multi-creative-1"
    data_spec_resource_path: "small_data_spec.textproto"
  }
  entity_key_specs {
    entity_type: "creative-id"
    entity_id: "edpa-eg-multi-creative-2"
    data_spec_resource_path: "small_data_spec_2.textproto"
  }
  entity_metadata {
    fields {
      key: "placement"
      value { string_value: "homepage_top" }
    }
    fields {
      key: "objective"
      value { string_value: "awareness" }
    }
  }
}

# edpa_meta's single-entity-key event group (second publisher for the TrusTee cross-publisher
# measurement). Identified solely by its `creative-id` entity key. Its impressions are AWS-KMS
# encrypted and generated in-test by WriteReusedLabeledImpressionsRule.
event_groups {
  event_group_reference_id: "edpa-eg-reference-id-2"
  edp_name: "edpa_meta"
  output_base_path: "edp/edpa_meta"
  entity_key_specs {
    entity_type: "creative-id"
    entity_id: "edpa-meta-creative"
    data_spec_resource_path: "small_data_spec.textproto"
  }
}
