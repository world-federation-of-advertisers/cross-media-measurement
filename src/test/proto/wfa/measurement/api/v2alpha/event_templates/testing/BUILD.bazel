load("@com_google_protobuf//bazel:proto_library.bzl", "proto_library")
load("@wfa_rules_kotlin_jvm//kotlin:defs.bzl", "kt_jvm_proto_library")

package(
    default_testonly = True,
    default_visibility = ["//visibility:public"],
)

IMPORT_PREFIX = "/src/test/proto"

proto_library(
    name = "duplicate_person_event_proto",
    srcs = ["duplicate_person_event.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = [
        "//src/main/proto/wfa/measurement/api/v2alpha/event_templates/testing:person_proto",
        "@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto",
    ],
)

kt_jvm_proto_library(
    name = "duplicate_person_event_kt_jvm_proto",
    deps = [":duplicate_person_event_proto"],
)
