# proto-file: wfa/measurement/api/v2alpha/event_group_metadata/testing/simulator_synthetic_data_spec.proto
# proto-message: SyntheticEventGroupSpec

# Stress-test spec for reproducing SWIOTLB buffer exhaustion on Confidential VMs.
#
# Designed for use with small_population_spec.textproto (100K VIDs).
# Covers 36 days (Mar 1 - Apr 5 2026) to match the Chevrolet production window.
# Run GenerateSyntheticData once per synthetic campaign (63 times with different
# --event-group-reference-id values) to produce ~2,268 blobs total.

date_specs {
  date_range {
    start {
      year: 2026
      month: 3
      day: 1
    }
    end_exclusive {
      year: 2026
      month: 4
      day: 6
    }
  }
  frequency_specs {
    frequency: 3
    vid_range_specs {
      vid_range {
        start: 1
        end_exclusive: 20001
      }
      non_population_field_values {
        key: "video_ad.viewed_fraction"
        value {
          double_value: 0.25
        }
      }
    }
  }
  frequency_specs {
    frequency: 5
    vid_range_specs {
      vid_range {
        start: 20001
        end_exclusive: 50001
      }
      non_population_field_values {
        key: "video_ad.viewed_fraction"
        value {
          double_value: 0.5
        }
      }
    }
  }
  frequency_specs {
    frequency: 2
    vid_range_specs {
      vid_range {
        start: 50001
        end_exclusive: 80001
      }
      non_population_field_values {
        key: "video_ad.viewed_fraction"
        value {
          double_value: 0.1
        }
      }
    }
  }
  frequency_specs {
    frequency: 4
    vid_range_specs {
      vid_range {
        start: 80001
        end_exclusive: 100000
      }
      non_population_field_values {
        key: "video_ad.viewed_fraction"
        value {
          double_value: 0.75
        }
      }
    }
  }
}
