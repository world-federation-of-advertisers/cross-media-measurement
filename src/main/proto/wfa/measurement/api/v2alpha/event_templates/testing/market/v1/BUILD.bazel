load("@com_google_protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_proto//proto:defs.bzl", "proto_descriptor_set")
load("@wfa_rules_kotlin_jvm//kotlin:defs.bzl", "kt_jvm_proto_library")

# Test-only protos that mimic the shape of a market-defined event template
# (single `Common` demographic message; discretized boolean engagement fields
# for Video and Display; an `Other` media-type slot). Used by
# GenerateAndVerifySyntheticDataTest to exercise the descriptor-set
# (DynamicMessage) code path of GenerateSyntheticData and VerifySyntheticData
# with a non-TestEvent event message type. Not synced to any external
# market-specific schema; see market_event.proto for full motivation.

package(
    default_testonly = True,
    default_visibility = ["//visibility:public"],
)

IMPORT_PREFIX = "/src/main/proto"

proto_library(
    name = "edp1_proto",
    srcs = ["edp1.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = ["@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto"],
)

proto_library(
    name = "common_proto",
    srcs = ["common.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = [
        ":edp1_proto",
        "@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto",
    ],
)

proto_library(
    name = "display_proto",
    srcs = ["display.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = ["@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto"],
)

proto_library(
    name = "video_proto",
    srcs = ["video.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = ["@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto"],
)

proto_library(
    name = "other_proto",
    srcs = ["other.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = ["@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto"],
)

proto_library(
    name = "market_event_proto",
    srcs = ["market_event.proto"],
    strip_import_prefix = IMPORT_PREFIX,
    deps = [
        ":common_proto",
        ":display_proto",
        ":other_proto",
        ":video_proto",
        "@wfa_measurement_proto//src/main/proto/wfa/measurement/api/v2alpha:event_annotations_proto",
    ],
)

kt_jvm_proto_library(
    name = "market_event_kt_jvm_proto",
    deps = [":market_event_proto"],
)

proto_descriptor_set(
    name = "market_event_descriptor_set",
    deps = [":market_event_proto"],
)
