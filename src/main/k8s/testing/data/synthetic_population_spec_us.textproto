# proto-file: wfa/measurement/api/v2alpha/population_spec.proto
# proto-message: PopulationSpec

# US population in 2023. The total population is 334,133,561.
# Source: https://www.census.gov/popclock/
#
# Only one demographic bucket (MALE / YEARS_18_TO_34 / A_B_C1, ~38.6M VIDs) is
# present here; the remaining VIDs in the 1..334,133,561 range are intentionally
# not modeled.
#
# Each SubPopulation declares its template attributes inline as a Person
# event template message embedded in a google.protobuf.Any. The event
# message type URL is supplied via the EDP simulator's
# --event-message-type-url CLI flag, and population / non-population field
# paths are introspected from the event message descriptor at runtime.

# Sub-population 1: MALE, YEARS_18_TO_34, A_B_C1 (~38,592,425 VIDs)
subpopulations {
  vid_ranges {
    start_vid: 1
    end_vid_inclusive: 38592425
  }
  attributes {
    [type.googleapis.com/wfa.measurement.api.v2alpha.event_templates.testing.Person] {
      gender: MALE
      age_group: YEARS_18_TO_34
      social_grade_group: A_B_C1
    }
  }
}
