# proto-file: wfa/measurement/api/v2alpha/population_spec.proto
# proto-message: PopulationSpec

# Small synthetic v2alpha PopulationSpec used in correctness and integration
# tests, with a 12-subpopulation layout covering VIDs 1..99999. The event
# message type URL is supplied via the EDP simulator's
# --event-message-type-url CLI flag (defaults to TestEvent).

# Sub-population 1: MALE, YEARS_18_TO_34, A_B_C1
subpopulations {
  vid_ranges {
    start_vid: 1
    end_vid_inclusive: 9999
  }
  attributes {
    [type.googleapis.com/wfa.measurement.api.v2alpha.event_templates.testing.Person] {
      gender: MALE
      age_group: YEARS_18_TO_34
      social_grade_group: A_B_C1
    }
  }
}

# Sub-population 2: MALE, YEARS_18_TO_34, C2_D_E
